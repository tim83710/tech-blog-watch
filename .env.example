# 複製成 .env（本機測試用；GitHub Actions 走 repo Secrets，不讀這個檔）
# .env 已在 .gitignore、不會被 commit

# Gemini API（摘要用；Google AI Studio 免費 tier）
# 取得：https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
# 選填：覆蓋 sources.yaml 的 model（不設就用 sources.yaml 的預設）
# GEMINI_MODEL=gemini-2.5-flash

# Slack Incoming Webhook（主力發送管道）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# 選填：現代 webhook 通常鎖定建立時選的頻道，這兩個可能被忽略
# SLACK_CHANNEL=#tech-blog-watch
# SLACK_USERNAME=tech-blog-watch

# Email（私人 Gmail SMTP；SMTP_PASSWORD 用「應用程式密碼」不是登入密碼）
SMTP_USER=yourname@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_TO=tim.chang@goodfinance.com
# 選填
# EMAIL_FROM=yourname@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
